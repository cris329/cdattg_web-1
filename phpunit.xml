<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         stopOnFailure="false"
         stopOnError="false">

    <!-- TEST SUITES POR MÓDULO -->
    <testsuites>

        <!-- Módulo Inventario -->
        <testsuite name="Inventario">
            <directory>tests/Inventario</directory>
        </testsuite>

        <!-- Módulo Complementarios -->
        <testsuite name="Complementarios">
            <directory>tests/Complementarios</directory>
        </testsuite>

    </testsuites>

    <!-- COVERAGE AUTOMÁTICO -->
    <source>
        <include>
            <!-- Inventario -->
            <directory>app/Inventario</directory>
            <directory>app/Models/Inventario</directory>
            <directory>app/Http/Controllers/Inventario</directory>
            <directory>app/Http/Requests/Inventario</directory>
            <directory>app/Livewire/Inventario</directory>

            <!-- Complementarios -->
            <directory>app/Http/Controllers/Complementarios</directory>
            <directory>app/Models/Complementarios</directory>
            <directory>app/Http/Requests/Complementarios</directory>
            <directory>app/Services/Complementarios</directory>
            <directory>app/Repositories/Complementarios</directory>
            <directory>app/Jobs/Complementarios</directory>
            <directory>app/Exceptions/Complementarios</directory>
        </include>
    </source>

    <coverage processUncoveredFiles="true">
        <include>
            <!-- Inventario -->
            <directory suffix=".php">app/Inventario</directory>
            <directory suffix=".php">app/Models/Inventario</directory>
            <directory suffix=".php">app/Http/Controllers/Inventario</directory>
            <directory suffix=".php">app/Http/Requests/Inventario</directory>
            <directory suffix=".php">app/Livewire/Inventario</directory>

            <!-- Complementarios -->
            <directory suffix=".php">app/Http/Controllers/Complementarios</directory>
            <directory suffix=".php">app/Models/Complementarios</directory>
            <directory suffix=".php">app/Http/Requests/Complementarios</directory>
            <directory suffix=".php">app/Services/Complementarios</directory>
            <directory suffix=".php">app/Repositories/Complementarios</directory>
            <directory suffix=".php">app/Jobs/Complementarios</directory>
            <directory suffix=".php">app/Exceptions/Complementarios</directory>
        </include>

        <report>
            <text outputFile="php://stdout" />
            <html outputDirectory="storage/coverage" />
        </report>
    </coverage>

    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="CACHE_DRIVER" value="array"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value="database/testing.sqlite"/>
        <env name="DB_FOREIGN_KEYS" value="true"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
    </php>
</phpunit>
